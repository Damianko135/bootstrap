{
  "metadata": {
    "version": "2.0.0",
    "author": "Damian Korver",
    "lastUpdated": "2025-12-22",
    "description": "Centralized configuration for laptop automation"
  },
  "bootstrap": {
    "logLevel": "INFO",
    "logDirectory": "$env:TEMP/laptopAutomation",
    "retryAttempts": 3,
    "retryDelaySeconds": 5,
    "maxParallelInstalls": 3,
    "timeoutSeconds": 600,
    "enableTelemetry": false,
    "backupPath": "$env:APPDATA/laptopAutomation/backups"
  },
  "packages": {
    "enableParallelInstall": true,
    "preferredManager": "winget",
    "fallbackManager": "choco",
    "validateInstallation": true,
    "installationProfiles": {
      "minimal": {
        "description": "Essential development tools only",
        "packages": ["Git", "PowerShell", "Visual Studio Code"]
      },
      "standard": {
        "description": "Standard development environment",
        "packages": "all_except_gaming"
      },
      "complete": {
        "description": "Full installation with all packages",
        "packages": "all"
      },
      "gaming": {
        "description": "Gaming-focused setup",
        "packages": ["Steam", "Discord", "Microsoft Teams"]
      }
    }
  },
  "system": {
    "requireAdmin": true,
    "requirePowerShellVersion": "5.1",
    "requireInternetConnection": true,
    "checkDiskSpace": true,
    "minimumDiskSpaceGB": 50
  },
  "notifications": {
    "enableNotifications": true,
    "notificationMethod": "toast",
    "verboseOutput": true
  }
}
