{
  "metadata": {
    "version": "2.1.0",
    "author": "Damian Korver",
    "lastUpdated": "2025-12-22",
    "description": "Centralized configuration for laptop automation"
  },
  "bootstrap": {
    "logLevel": "INFO",
    "logDirectory": "$env:TEMP/laptopAutomation",
    "retryAttempts": 3,
    "retryDelaySeconds": 5,
    "maxParallelInstalls": 3,
    "timeoutSeconds": 600,
    "enableTelemetry": false,
    "backupPath": "$env:APPDATA/laptopAutomation/backups"
  },
  "packages": {
    "enableParallelInstall": true,
    "preferredManager": "winget",
    "fallbackManager": "choco",
    "validateInstallation": true,
    "enableDependencyResolution": true,
    "detectConflicts": true,
    "sortByDependencies": true,
    "dryRunMode": false,
    "installationProfiles": {
      "minimal": {
        "description": "Essential development tools only",
        "packages": ["Git", "PowerShell", "Visual Studio Code"]
      },
      "standard": {
        "description": "Standard development environment",
        "packages": "all_except_gaming"
      },
      "complete": {
        "description": "Full installation with all packages",
        "packages": "all"
      },
      "gaming": {
        "description": "Gaming-focused setup",
        "packages": ["Steam", "Discord", "Microsoft Teams"]
      }
    }
  },
  "system": {
    "requireAdmin": true,
    "requirePowerShellVersion": "5.1",
    "requireInternetConnection": true,
    "checkDiskSpace": true,
    "minimumDiskSpaceGB": 50
  },
  "recovery": {
    "enableCheckpoints": true,
    "checkpointDirectory": "$env:APPDATA/laptopAutomation/checkpoints",
    "enableAutoRecovery": true,
    "checkpointEveryPhase": true,
    "maxCheckpoints": 10
  },
  "validation": {
    "enablePostInstallValidation": true,
    "enableHealthChecks": true,
    "enableRepairMode": true,
    "repairFailedPackages": false,
    "stopOnValidationError": false
  },
  "hooks": {
    "enableHookSystem": true,
    "hookDirectory": "$PSScriptRoot/hooks",
    "loadCustomHooks": true,
    "executePreSetup": true,
    "executePostSetup": true
  },
  "telemetry": {
    "enableTelemetry": false,
    "collectMetrics": true,
    "generateReport": true,
    "reportPath": "$env:APPDATA/laptopAutomation/reports",
    "telemetryEndpoint": null,
    "anonymizeReport": true
  },
  "notifications": {
    "enableNotifications": true,
    "notificationMethod": "toast",
    "verboseOutput": true,
    "showSummaryOnCompletion": true
  }
}
